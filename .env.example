# Exa
EXA_API_KEY=
# Secret shown once when you create the webhook in Exa (HMAC verification on POST /webhook)
EXA_WEBHOOK_SECRET=
# Optional override (default https://api.exa.ai/websets)
# EXA_BASE_URL=https://api.exa.ai/websets
# Local only — never enable in production
# EXA_SKIP_WEBHOOK_SIGNATURE_VERIFY=false

# Ashby (HTTP Basic: use API key as username, empty password unless Ashby docs say otherwise)
ASHBY_API_KEY=
BRANDON_ASHBY_USER_ID=

# Slack — channel summaries (incoming webhook) + DM alerts (bot)
SLACK_INCOMING_WEBHOOK_URL=
SLACK_BOT_TOKEN=
BRANDON_SLACK_USER_ID=

# Admin UI + /api/* (HTTP Basic)
ADMIN_BASIC_USER=
ADMIN_BASIC_PASSWORD=

# GET /catch-up — require header matching this value (e.g. X-Cron-Secret)
CATCH_UP_SECRET=

# SQLite — local default; on Railway mount a volume and use e.g. DATABASE_PATH=/data/app.db
DATABASE_PATH=data/app.db

# Log actions but do not write to Ashby when true
DRY_RUN=false
